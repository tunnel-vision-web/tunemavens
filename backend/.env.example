# --- Mongo (shared with intermaven.io per DOCUMENTATION.md §9.1) ---
MONGO_URL=mongodb://localhost:27017
DB_NAME=intermaven

# --- JWT (MUST be identical to intermaven.io's JWT_SECRET for cross-portal SSO) ---
JWT_SECRET=intermaven_secret_key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# --- Cookie (cross-subdomain) ---
# Leave empty in local dev (browsers reject Domain on localhost).
# In prod set to ".intermaven.io" so the same cookie is sent on tunemavens.com if/when it shares the parent.
# tunemavens.com is a different eTLD+1 from intermaven.io — see backend/README.md for the SSO bridge approach.
COOKIE_DOMAIN=
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# --- CORS ---
# Comma-separated. In production list both portals' origins explicitly.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,https://tunemavens.com,https://www.tunemavens.com,https://djs.tunemavens.com,https://labels.tunemavens.com,https://producers.tunemavens.com,https://mediahouses.tunemavens.com
