{
  "name": "tunemaven-monorepo",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:portal": "npm run dev --workspace=portal",
    "build:portal": "npm run build --workspace=portal",
    "dev:tunestream": "npm run dev --workspace=tunestream",
    "build:tunestream": "npm run build --workspace=tunestream",
    "dev:syncmavens": "npm run dev --workspace=syncmavens",
    "build:syncmavens": "npm run build --workspace=syncmavens",
    "dev:api": "npm run dev --workspace=api",
    "build:all": "npm run build --workspaces --if-present",
    "build": "npm run build --workspaces --if-present"
  }
}
