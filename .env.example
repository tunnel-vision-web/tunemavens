# Leave blank in dev when running Vite and the API behind the same nginx
# (Phase 1 config in backend/README.md). Set to the absolute backend URL
# when developing the SPA in isolation.
#
# Examples:
#   VITE_API_BASE_URL=http://localhost:8001
#   VITE_API_BASE_URL=https://api.tunemavens.com
VITE_API_BASE_URL=
